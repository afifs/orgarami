{
  "name": "orgarami",
  "version": "1.0.0",
  "description": "Org Map \u2014 desktop app",
  "author": "Afif Say",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.orgarami",
    "productName": "OrgMap",
    "icon": "src/icon.ico",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "locales/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OrgChart Viewer"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}