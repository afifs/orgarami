    "techSection": "Built with",
    "features": {
      "localRemote": {
        "title": "Local & Remote CSV",
        "desc": "Open files or fetch from any HTTP/HTTPS URL"
      },
      "editor": {
        "title": "In-app editor",
        "desc": "Add, edit, and delete nodes with live chart update"
      },
      "reparent": {
        "title": "Smart re-parenting",
        "desc": "Deleted node's children auto-connect to its parent"
      },
      "saveCsv": {
        "title": "Save as CSV",
        "desc": "UTF-8 BOM output — opens correctly in Excel"
      },
      "print": {
        "title": "Print & Tiled export",
        "desc": "System print dialog and multi-page PDF tiling"
      },
      "export": {
        "title": "SVG / PNG export",
        "desc": "Vector and raster export for documents"
      },
      "multiOrg": {
        "title": "Multi-org support",
        "desc": "Multiple organisations in a single CSV file"
      },
      "session": {
        "title": "Session restore",
        "desc": "Remembers the last opened file across sessions"
      },
      "undoRedo": {
        "title": "Undo / Redo",
        "desc": "Full edit history with Ctrl+Z / Ctrl+Y"
      },
      "i18n": {
