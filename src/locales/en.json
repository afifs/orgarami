  "about": {
    "title": "About Orgarami",
    "version": "Version 1.0.0",
    "description": "A lightweight desktop application for viewing and editing organisational charts from CSV data. Load files locally or from remote URLs, edit nodes in place, and export to SVG or print directly.",
